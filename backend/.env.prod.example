# Copy to .env.prod for Docker full stack:
#   cp .env.prod.example .env.prod
# Then fill in secrets (JWT).

JWT_SECRET=
DB_URL=
DB_USERNAME=
DB_PASSWORD=
REDIS_HOST=
SERVER_PORT=
# Media local storage (trỏ vào volume media_data mount tại /var/www/media)
MEDIA_ROOT=/var/www/media
MEDIA_URL_PREFIX=/media
